'----------以下おまけの便利関数

'----------------------------------------------------------------------------------------------------+
'----------Title：FindWindowTitle
'----------概要：引数で指定した文字列が含まれているウィンドウに切り替える関数
'-----パラメータ：・WebDriver
'-----------------・TimeoutSec
'-----------------・InputText（※検索対象のウィンドウタイトル名）
'-----戻り値：タイムアウトまでに指定タイトルのウィンドウへの切り替えに成功したかどうかの真偽値
'----------------------------------------------------------------------------------------------------+
Public Function FindWindowTitle() As Boolean
    Const PROCEDURE_NAME As String = "FindWindowTitle"
    Call ErrorLog.TraceListPush(MODULE_NAME, PROCEDURE_NAME)
    On Error GoTo ErrorHandler
   
    Dim startTime As Double
    Dim i As Long
    Dim hwnds As Selenium.List
    Set hwnds = WebDriver.Send("GET", "/window_handles")
    FindWindowTitle = False
    
    '開始時間から第三引数で指定した秒数の間繰り返す
    startTime = Timer
    Do While Timer - startTime < TimeoutSec
    
        'オブジェクトのウィンドウタイトルを一週分順番に切り替え、参照中ウィンドウタイトルに指定した文字列が含まれている場合、正常終了する
        ' ※perLoppにしてるのは用意されたメソッドでは現在のハンドルが取得する方法がない為、ハンドル分switchする事で見つからない場合でも
        '　　最初のウィンドウの参照へリセットできるようにした
        For i = 1 To WebDriver.Windows.count
        On Error Resume Next
            '参照中ウィンドウタイトルに第二引数の文字列が含まれていれば正常終了
            If InStr(WebDriver.Window.Title, InputText) > 0 Then
                '直前の閉じる等で.Window.titleが消失している状態の場合はエラーを起こし、On Error Resume Nextで握り潰すと条件式を無視してそのまま通過してしまう為ここでハンドリングする
                If Err.Number = 0 Then
                    WebDriver.Wait DELAY_MS
                    FindWindowTitle = True
                    GoTo CleanExit 'Exit
                End If
            End If

            '次のウィンドウへ切り替える
            
            WebDriver.SwitchToNextWindow
            '最後尾の時点で次のウィンドウへ切り替えをするとエラーが発生するので、エラー時は最初のウィンドウに切り替える
            If Err.Number <> 0 Then
                WebDriver.Window.SwitchToWindowByName hwnds.Item(1)
                Err.Number = 0
            End If
            On Error GoTo ErrorHandler

        Next i
        WebDriver.Wait DELAY_MS
    Loop
    FindWindowTitle = False
    
CleanExit:
    ErrorLog.TraceListPop
    Exit Function
ErrorHandler:
        Err.Raise Err.Number, MODULE_NAME & "." & PROCEDURE_NAME, Err.Description
End Function


'----------------------------------------------------------------------------------------------------+
'----------Title：FindAlert
'----------概要：引数で指定したwebDriverのオブジェクトでアラートダイアログが表示されていればそれを返却する
'-----パラメータ：・WebDriver
'-----------------・TimeoutSec
'-----戻り値：タイムアウトまでにアラートが発見できた場合、アラートのオブジェクトを返却
'-----ヒント：この関数の戻り値がNot Nothingなら.Acceptをしてアラートを閉じる等の用法が考えられる
'----------------------------------------------------------------------------------------------------+
Public Function FindAlert() As Object
    Const PROCEDURE_NAME As String = "FindAlert"
    Call ErrorLog.TraceListPush(MODULE_NAME, PROCEDURE_NAME)
    On Error GoTo ErrorHandler
   
    Dim alertObj As Object
    Dim startTime As Double
    Set FindAlert = Nothing

    '開始時間から第二引数で指定した秒数の間繰り返す
    On Error Resume Next ' エラーを一時的に無視
    startTime = Timer
    Do While Timer < startTime + TimeoutSec
        ' アラートの切り替えを試みる
        Set alertObj = WebDriver.SwitchToAlert()
        'アラートダイアログを発見
        If Err.Number = 0 Then
            Set FindAlert = alertObj
            GoTo CleanExit 'Exit
        End If
        WebDriver.Wait DELAY_MS
    Loop
    On Error GoTo ErrorHandler
    
CleanExit:
    ErrorLog.TraceListPop
    Exit Function
ErrorHandler:
        Err.Raise Err.Number, MODULE_NAME & "." & PROCEDURE_NAME, Err.Description
End Function


'----------------------------------------------------------------------------------------------------+
'----------Title：WaitUntilElementPresent
'----------概要：引数で指定したオブジェクトが読み込まれるまで待機する関数
'-----パラメータ：・WebDriver
'-----------------・TimeoutSec
'-----------------・SelectorFind（webElm）
'-----------------・Target（webElm）
'-----------------・IndexNumber（webElm）
'-----------------・RaiseFlag
'-----Arg1：検索対象のwebDriverのオブジェクト
'-----Arg2：検索する属性名
'-----Arg3：検索するオブジェクト名
'-----Arg4：検索のタイムアウト秒数時間。デフォルトで10秒間
'-----Arg5：検索失敗時にエラーを発生させるかどうかの真偽値
'-----戻り値：タイムアウトまでにオブジェクトが発見できたかどうかの真偽値
'----------------------------------------------------------------------------------------------------+
Public Function WaitUntilElementPresent() As Boolean
    Const PROCEDURE_NAME As String = "WaitUntilElementPresent"
    Call ErrorLog.TraceListPush(MODULE_NAME, PROCEDURE_NAME)
    On Error GoTo ErrorHandler

    Dim startTime As Double
    Dim count As Long
    startTime = Timer
    Do While Timer - startTime < TimeoutSec
        count = 0
        On Error Resume Next

        count = webElm.count

        On Error GoTo ErrorHandler
        
        ' 要素が1つ以上見つかれば成功
        If count > 0 Then
            WaitUntilElementPresent = True
            GoTo CleanExit 'Exit
        End If
        
        WebDriver.Wait DELAY_MS ' 0.2秒刻みでチェック
        DoEvents
    Loop
    
    WaitUntilElementPresent = False
    
    If RaiseFlag Then Err.Raise Number:=513, Description:="DOT読込エラーです。通信状態を確認後、再度実行してください。"
    
CleanExit:
    ErrorLog.TraceListPop
    Exit Function
ErrorHandler:
        Err.Raise Err.Number, MODULE_NAME & "." & PROCEDURE_NAME, Err.Description
End Function

